---
title: Anonymisation-ProArchive Architecture
---

flowchart TB
    %% ── Input ──
    INPUT(["Document<br/>(PDF / TXT / DOCX / Image)"])
    INPUT --> INGESTION

    %% ── 1. Ingestion Layer ──
    subgraph INGESTION ["1. Document Ingestion"]
        direction TB
        READ[read_file<br/>detect extension]
        TXT_LOADER["txt_loader (.txt, .md, .csv)"]
        PDF_LOADER["pdf_loader (.pdf)"]
        DOCX_LOADER["docx_loader (.docx)"]
        IMG_LOADER["image_loader (.png, .jpg)"]
        READ --> TXT_LOADER
        READ --> PDF_LOADER
        READ --> DOCX_LOADER
        READ --> IMG_LOADER
    end

    INGESTION --> LANG_ROUTER

    %% ── 2. Language Detection & NLP Pipelines ──
    subgraph LANG_ROUTER ["2. Language Detection & NLP Pipelines"]
        LANG_DETECT["Language Detector<br/>(langdetect)"]
        LANG_DETECT -->|en| EN_PIPELINE
        LANG_DETECT -->|fr| FR_PIPELINE
        LANG_DETECT -->|ar| AR_PIPELINE

        EN_PIPELINE["EN Pipeline<br/>en_core_web_lg (spaCy)"]
        FR_PIPELINE["FR Pipeline<br/>fr_core_news_md (spaCy)"]
        AR_PIPELINE["AR Pipeline<br/>_SafeNlpEngine wrapper  ←  No Arabic spaCy model<br/>returns empty NlpArtifacts<br/>→ regex + deny-lists only"]
    end

    EN_PIPELINE --> ANALYZER
    FR_PIPELINE --> ANALYZER
    AR_PIPELINE --> ANALYZER

    %% ── 3. Analyzer (Detection) ──
    subgraph ANALYZER ["3. PII Detection Engine"]

        subgraph PRESIDIO_CORE ["Presidio AnalyzerEngine (EN / FR / AR)"]
            REMOVED["❌ Removed US/UK recognizers<br/>(SSN, ITIN, passport, NHS, etc.)<br/>❌ Crypto, MedicalLicense, MAC"]
            KEPT["✅ Retained default recognizers<br/>EMAIL, CREDIT_CARD (Luhn),<br/>IP, URL, IBAN, PHONE_NUMBER"]
        end

        subgraph LANGUAGE_REGISTRATION ["Registered for en, fr, ar"]
            CUSTOM["Custom PatternRecognizers (x3 languages)"]
        end

        subgraph CUSTOM ["Custom (Algerian-specific) — all score 0.95"]
            direction TB
            DZ_PHONE["📞 DZ_PHONE<br/>\b(05|06|07)\d{8}\b"]
            DZ_NIN["🆔 DZ_NIN<br/>\b\d{6}\s?\d{6}\s?\d{6}\b"]
            DZ_PASSPORT["📘 DZ_PASSPORT<br/>\b[A-Z]{2}\d{6}\b"]
            DZ_RIB["🏦 DZ_RIB<br/>\b\d{20}\b"]
            DZ_RC["🏢 DZ_RC<br/>\b[A-Z]{1,2}\d{7,10}\b"]
            DZ_NIF["🧾 DZ_NIF<br/>\b\d{15}\b"]
            DZ_WILAYA["🗺️ DZ_WILAYA<br/>codes 01–58 (score 0.3)"]
            DZ_POSTAL["📫 DZ_POSTAL<br/>\b(01–58)\d{3}\b (score 0.85)"]
            DZ_SSN["🆔 DZ_SSN<br/>\b[12]\d{12,14}\b"]
        end

        subgraph DENY_LISTS ["Deny-List Recognizers (EN / FR / AR)"]
            LOC_DENY["LOCATION<br/>58 wilaya names<br/>(Adrar, Alger, Oran, Tizi Ouzou…)"]
            PER_DENY["PERSON<br/>120+ common Maghrebi first names<br/>(Mohamed, Ahmed, Ali, Fatima…)"]
        end
    end

    ANALYZER -->|analyzer_results| RISK_CLASSIFIER

    %% ── 4. Risk Classifier ──
    subgraph RISK_CLASSIFIER ["4. Risk Classifier (Legal Layer)"]
        CAT_I["Cat I: Direct Identifiers<br/>PERSON, EMAIL, PHONE, NIN, PASSPORT,<br/>RIB, RC, NIF, SSN, CREDIT_CARD"]
        CAT_II["Cat II: Quasi-Identifiers<br/>LOCATION, DATE_TIME, WILAYA, POSTAL,<br/>IP, URL, IBAN"]
        CAT_III["Cat III: Sensitive Data<br/>HEALTH, RELIGION, POLITICS<br/><b>→ BLOCK (Art. 18)</b>"]

        CAT_I -->|must remove| ANONYMIZER
        CAT_II -->|k-anonymize| ANONYMIZER
        CAT_III --> BLOCK["❌ Document Rejected"]
    end

    ANONYMIZER -->|operators + text| OUTPUT

    %% ── 5. Anonymizer ──
    subgraph ANONYMIZER ["5. Anonymization Engine"]
        PRESIDIO_ANONYM["Presidio AnonymizerEngine"]
        REPLACE["replace → &lt;ALGERIAN_CITIZEN&gt;<br/>&lt;ID_REDACTED&gt;, &lt;RC_REDACTED&gt;"]
        HASH["hash → SHA-256<br/>for EMAIL_ADDRESS"]
        MASK["mask → ******4567<br/>for PHONE, RIB, POSTAL"]
        REDACT["redact → remove entirely"]

        PRESIDIO_ANONYM --> REPLACE
        PRESIDIO_ANONYM --> HASH
        PRESIDIO_ANONYM --> MASK
        PRESIDIO_ANONYM --> REDACT
    end

    %% ── 6. Post-Processing & Output ──
    subgraph OUTPUT ["6. Post-Processing & Output"]
        direction TB
        TEXT_OUT["Sanitized Text"]
        META_OUT["Metadata JSON"]
        AUDIT["Audit Log (Art. 38)"]
    end

    TEXT_OUT -->|"→ Cloud LLM"| LLM["GPT-4 / Claude / Gemini"]
    META_OUT --> LOCAL["Local Storage"]
    AUDIT --> LOCAL

    %% ── Legend ──
    LEGEND_INGESTION -.->|"📄 File readers"| INGESTION
    LEGEND_CLASSIFIER -.->|"⚖️ Legal baseline (Loi 18-07 / 25-11)"| RISK_CLASSIFIER
    LEGEND_ANONYMIZER -.->|"🔐 Strategies per entity"| ANONYMIZER
    LEGEND_AR -.->|"⚠️ Arabic: regex/deny only (no spaCy model)"| LANG_ROUTER
