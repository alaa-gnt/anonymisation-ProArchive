---
title: Anonymisation-ProArchive Architecture
---

flowchart TB
    %% ── Input ──
    INPUT(["Document<br/>(PDF / TXT / DOCX / Image)"])
    INPUT --> INGESTION

    %% ── 1. Ingestion Layer ──
    subgraph INGESTION ["1. Document Ingestion"]
        direction TB
        READ["read_file(path)
        ───────────────
        ① Path → extension
        ② LOADERS[ext] lookup
        ③ loader.load(path)
        ④ return (text, metadata)"]

        subgraph MODELS ["Data Models"]
            TB_MODEL["TextBlock:  text, page, bbox, block_type"]
            SD_MODEL["StructuredDocument:  text, blocks[], metadata{}"]
        end

        REG["LOADERS dict
        ────────────
        .txt → TxtLoader
        .md  → TxtLoader
        .csv → TxtLoader
        .pdf → PdfLoader
        .docx→ DocxLoader
        .png → ImageLoader
        .jpg → ImageLoader
        .tiff→ ImageLoader"]

        TXT["TxtLoader
        ─────────
        utf-8→latin-1→cp1256
        1 block per line
        no bbox"]

        PDF["PdfLoader
        ─────────
        PyMuPDF (fitz)
        1 block per page block
        with bbox + page"]

        DOCX["DocxLoader
        ──────────
        python-docx
        1 block per paragraph
        no bbox, page=0"]

        IMG["ImageLoader
        ──────────
        Tesseract OCR
        lang=ara+fra+eng
        words→lines with bbox
        ✅ Position preserved"]

        READ --> REG
        REG --> TXT
        REG --> PDF
        REG --> DOCX
        REG --> IMG
        TXT --- MODELS
        PDF --- MODELS
        DOCX --- MODELS
        IMG --- MODELS
    end

    %% ── 2. NLP Pipelines (Multi-pass: EN + FR + AR) ──
    subgraph NLP ["2. NLP Pipelines (Multi-pass)"]
        EN_PIPELINE["① EN Pass<br/>Stanza (en)<br/>→ NER (PERSON, ORG, LOC, DATE)"]
        FR_PIPELINE["② FR Pass<br/>Stanza (fr)<br/>→ NER (PER, ORG, LOC, DATE)"]
        AR_PIPELINE["③ AR Pass<br/>Stanza (ar)<br/>→ NER (PER, ORG, LOC, MISC)"]
    end

    INGESTION --> EN_PIPELINE
    INGESTION --> FR_PIPELINE
    INGESTION --> AR_PIPELINE

    EN_PIPELINE --> ANALYZER
    FR_PIPELINE --> ANALYZER
    AR_PIPELINE --> ANALYZER

    %% ── 3. Analyzer (Detection) ──
    subgraph ANALYZER ["3. PII Detection Engine"]

        subgraph PRESIDIO_CORE ["Presidio AnalyzerEngine (EN / FR / AR)"]
            REMOVED["❌ Removed US/UK recognizers<br/>(SSN, ITIN, passport, NHS, etc.)<br/>❌ Crypto, MedicalLicense, MAC"]
            KEPT["✅ Retained default recognizers<br/>EMAIL, CREDIT_CARD (Luhn),<br/>IP, URL, IBAN, PHONE_NUMBER"]
        end

        subgraph ALGERIAN ["Custom Recognizer Subclasses (src/recognizers/)"]
            DZ_PHONE["📞 DZ_PHONE<br/>mobile: \b(05|06|07)\d{8}\b<br/>landline: \b0[234]\d{7,8}\b"]
            DZ_NIN["🆔 DZ_NIN<br/>\b\d{6}\s?\d{6}\s?\d{6}\b<br/>🔢 Luhn checksum filter"]
            DZ_PASSPORT["📘 DZ_PASSPORT<br/>\b\d{9}\b<br/>(fixed from old [A-Z]{2}\d{6})"]
            DZ_RIB["🏦 DZ_RIB<br/>\b\d{20}\b<br/>🔢 mod-97 checksum filter"]
            DZ_IBAN["🏦 IBAN_CODE<br/>\bDZ\d{22}\b<br/>🔢 mod-97 checksum filter"]
            DZ_RC["🏢 DZ_RC<br/>CNRC: YY/WW-SSSSSS[L]<br/>wilaya-validated"]
            DZ_NIF["🧾 DZ_NIF<br/>\b\d{15}\b"]
            DZ_NIS["🧾 DZ_NIS<br/>\b\d{15}\b"]
            DZ_POSTAL["📫 DZ_POSTAL<br/>\b(01–58)\d{3}\b (score 0.85)"]
        end

        subgraph DENY_LISTS ["Deny-List Recognizers (EN / FR / AR)"]
            LOC_DENY["LOCATION<br/>58 wilaya names<br/>(Adrar, Alger, Oran, Tizi Ouzou…)"]
            PER_DENY["PERSON<br/>120+ common Maghrebi first names<br/>(Mohamed, Ahmed, Ali, Fatima…)"]
        end

        subgraph GLINER ["🆕 GLiNER Recognizer (src/recognizers/dz_gliner.py)"]
            GLINER_ENGINE["DZGlinerRecognizer<br/>Zero-shot NER — no training needed<br/>Model: urchade/gliner_multi_pii-v1<br/>Entity mapping: national id number → DZ_NIN<br/>passport number → DZ_PASSPORT<br/>phone number → DZ_PHONE<br/>email address → EMAIL_ADDRESS<br/>iban → IBAN_CODE<br/>bank account number → DZ_RIB"]
        end
    end

    ANALYZER --> MERGE

    %% ── 3.5 Result Merge (multi-language) ──
    subgraph MERGE ["3.5 Multi-Language Result Merge"]
        MERGE_FN["_merge_results()"]
        FILTER["Cross-language NER filter<br/>FR/EN NER on Arabic-script text → dropped"]
        OVERLAP["Overlapping spans → keep highest score / longest span"]
        MERGE_FN --> FILTER
        FILTER --> OVERLAP
    end

    MERGE --> RISK_CLASSIFIER

    %% ── 4. Risk Classifier ──
    subgraph RISK_CLASSIFIER ["4. Risk Classifier (Legal Layer) — NOT IMPLEMENTED"]
        CAT_I["Cat I: Direct Identifiers<br/>PERSON, EMAIL, PHONE, NIN, PASSPORT,<br/>RIB, RC, NIF, NIS, CREDIT_CARD"]
        CAT_II["Cat II: Quasi-Identifiers<br/>LOCATION, DATE_TIME, POSTAL,<br/>IP, URL, IBAN"]
        CAT_III["Cat III: Sensitive Data<br/>HEALTH, RELIGION, POLITICS<br/><b>→ BLOCK (Art. 18)</b>"]
    end

    CAT_I -->|pseudonymize| ANONYMIZER
    CAT_II -->|pseudonymize| ANONYMIZER
    CAT_III --> BLOCK["❌ Document Rejected"]

    ANONYMIZER -->|anonymized text| OUTPUT

    %% ── 5. Anonymizer (Pure Pseudonymization) ──
    subgraph ANONYMIZER ["5. Pseudonymization Pipeline"]
        ASSIGN["_assign_pseudonyms()<br/>group unique values per entity type<br/>→ &lt;PERSON_1&gt;, &lt;DZ_PHONE_1&gt;<br/>→ &lt;LOCATION_1&gt;, &lt;EMAIL_ADDRESS_1&gt;"]
        APPLY["Right-to-left text replacement<br/>preserving original offsets"]
        ASSIGN --> APPLY
    end

    %% ── 6. Post-Processing & Output ──
    subgraph OUTPUT ["6. Post-Processing & Output"]
        direction TB
        TEXT_OUT["Sanitized Text"]
        META_OUT["Metadata JSON"]
        AUDIT["Audit Log (Art. 38)"]
    end

    TEXT_OUT -->|"→ Cloud LLM"| LLM["GPT-4 / Claude / Gemini"]
    META_OUT --> LOCAL["Local Storage"]
    AUDIT --> LOCAL

    %% ── Legend ──
    LEGEND_INGESTION -.->|"📄 File readers"| INGESTION
    LEGEND_ANONYMIZER -.->|"🔐 Custom pseudonymization"| ANONYMIZER
    LEGEND_ENGINE -.->|"🔁 StanzaNlpEngine (en + fr + ar)<br/>Shared singleton via get_analyzer()"| NLP
